{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PromptTemplateSpecification",
  "type": "object",
  "properties": {
    "templateName": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "systemInstructions": {
      "type": "string"
    },
    "templateText": {
      "type": "string"
    },
    "variables": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["string", "number", "boolean", "array", "object"] },
          "description": { "type": "string" }
        },
        "required": ["type"]
      }
    },
    "required": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "templateName",
    "version",
    "templateText",
    "variables"
  ]
}
